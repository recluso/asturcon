---
export const prerender = false;

import BlogPost from '../layouts/BlogPost.astro';

let success = false;
let error = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name");
    const email = data.get("email");
    const message = data.get("message");

    // Keep the robust key detection 
    const apiKey = import.meta.env.RESEND_API_KEY || Astro.locals.runtime?.env?.RESEND_API_KEY;
    
    if (!apiKey) {
      console.error("CRITICAL: RESEND_API_KEY is missing from environment.");
      throw new Error("Configuration Error");
    }

    const response = await fetch("https://api.resend.com/emails", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        // Change this to your verified domain email now!
        from: "Sacha Asturcon <contact@asturcon.red>",
        to: ["recluso@icloud.com"], 
        reply_to: email as string,
        subject: `New Message from ${name}`,
        html: `<p><strong>Name:</strong> ${name}</p>
               <p><strong>Email:</strong> ${email}</p>
               <p><strong>Message:</strong> ${message}</p>`,
      }),
    });

    if (response.ok) {
      success = true;
    } else {
      const result = await response.json() as any;
      console.error("Resend API rejection:", result);
      throw new Error("API Rejection");
    }
  } catch (e) {
    // We log the real error for you to see in the terminal/Cloudflare logs
    console.error("Contact Form Submission Failure:", e);
    // But we only show the user a polite generic error
    error = true;
  }
}
---

<BlogPost title="Contact" description="Get in touch" pubDate={new Date()}>
  <div class="contact-form-container">
    

    {success ? (
      <div class="message success">
        <p>✅ Message sent! I'll get back to you soon.</p>
      </div>
    ) : (
      <>
        {error && (
          <div class="message error">
            <p>❌ Sorry, something went wrong. Please try again later.</p>
          </div>
        )}

        <form method="POST">
          <div class="input-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="input-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="input-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>

          <button type="submit">Send Message</button>
        </form>
      </>
    )}
  </div>
</BlogPost>

<style>
  .contact-form-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .input-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
  }
  label {
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  input, textarea {
    padding: 0.8rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    width: 100%;
  }
  button {
    background: #333;
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    width: 100%;
  }
  button:hover {
    background: #000;
  }
  .message {
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
  .error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
  .success a { color: #155724; font-weight: bold; }
</style>